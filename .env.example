DISCORD_TOKEN=your_bot_token_here
DISCORD_PUBLIC_KEY=your_application_public_key_here
DISCORD_CLIENT_ID=your_application_client_id_here
DISCORD_GUILD_ID=your_test_server_id_here
VOTE_CHANNEL_ID=your_vote_channel_id_here
ENABLE_WELCOME_MESSAGES=false
WELCOME_CHANNEL_ID=your_welcome_channel_id_here
MUSIC_VOICE_CHANNEL_ID=your_voice_channel_id_here
MUSIC_FILE_PATH=/home/container/My Ordinary Life-The Living Tombstone.mp3
MUSIC_VOLUME=0.5
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# For cloud hosts, prefer either FIREBASE_SERVICE_ACCOUNT_JSON or the three separate Firebase fields below.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# FIREBASE_PROJECT_ID=your_firebase_project_id
# FIREBASE_CLIENT_EMAIL=your_firebase_client_email
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
